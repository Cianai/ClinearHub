        { "title": "Shift", "type": "dropdown" },
        { "title": "Operator", "type": "text" },
        { "title": "Downtime (hrs)", "type": "numbers" },
        { "title": "Downtime Reason", "type": "dropdown" },
        { "title": "Scrap / Waste Units", "type": "numbers" },
        { "title": "Customer Order Ref", "type": "text" },
        { "title": "Notes", "type": "long_text" }
      ],
      "groups": [
