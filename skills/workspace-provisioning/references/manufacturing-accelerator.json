  "relations": [
    {
      "from": "Quality Control",
      "to": "Production Planning",
      "title": "Production Batch"
    },
    {
      "from": "Production Planning",
      "to": "Quality Control",
      "title": "QC Inspections"
    },
    {
      "from": "Production Planning",
      "to": "Inventory Management",
      "title": "Materials Used"
    },
    {
      "from": "Inventory Management",
      "to": "Supplier Management",
      "title": "Preferred Supplier"
    },
    {
      "from": "Dispatch & Delivery",
      "to": "Production Planning",
      "title": "Production Order"
    },
    {
      "from": "Production Planning",
      "to": "Dispatch & Delivery",
      "title": "Shipments"
    },
    {
      "from": "Supplier Management",
      "to": "Inventory Management",
      "title": "Items Supplied"
    }
  ],
  "dashboards": [
    {
      "name": "Production Overview",
      "kind": "PRIVATE",
      "widgets": [
        { "kind": "BATTERY", "name": "Production Status", "board": "Production Planning", "status_column": "status" },
        { "kind": "NUMBER", "name": "Active Orders", "board": "Production Planning", "settings_type": "counter", "counter_type": "sum" },
        { "kind": "CHART", "name": "Orders by Priority", "board": "Production Planning", "graph_type": "pie", "x_column": "status", "y_column": "name" }
      ]
    },
    {
      "name": "Quality Dashboard",
      "kind": "PRIVATE",
      "widgets": [
        { "kind": "CHART", "name": "QC Pass/Fail Rate", "board": "Quality Control", "graph_type": "pie", "x_column": "status", "y_column": "name" },
        { "kind": "BATTERY", "name": "QC Progress", "board": "Quality Control", "status_column": "status" },
        { "kind": "NUMBER", "name": "Open Inspections", "board": "Quality Control", "settings_type": "counter", "counter_type": "sum" }
      ]
    },
    {
      "name": "Inventory Dashboard",
      "kind": "PRIVATE",
      "widgets": [
        { "kind": "NUMBER", "name": "Total SKUs", "board": "Inventory Management", "settings_type": "counter", "counter_type": "sum" },
        { "kind": "BATTERY", "name": "Stock Levels", "board": "Inventory Management", "status_column": "status" }
      ]
    }
  ],
  "manualSteps": [
    "Set up automations: when Inventory 'Current Stock' drops below 'Reorder Point' -> move to 'Below Reorder Point' group + notify procurement",
    "Set up automations: when Production 'Status' changes to 'Completed' -> create Quality Control inspection item",
    "Set up automations: when Quality Control 'Accept / Reject' changes to 'Reject' -> update Production 'Status' to 'Quality Hold'",
    "Set up automations: when Supplier 'Contract Expiry' is 30 days away -> notify procurement to review",
    "Set up automations: when Dispatch 'Delivery Status' changes to 'Delivered' -> update Production 'Status' to 'Completed'",
    "Configure status labels: Production Priority (Urgent, High, Standard, Low)",
    "Configure status labels: Production Status (Scheduled, In Production, Quality Hold, Completed, Canceled)",
    "Configure status labels: QC Result (Pass, Conditional Pass, Fail, Pending)",
    "Configure status labels: Accept / Reject (Accept, Reject, Conditional Accept)",
    "Configure status labels: Supplier Rating (Excellent, Good, Satisfactory, Poor, Critical)",
    "Configure status labels: Stock Status (In Stock, Low Stock, Out of Stock, Discontinued)",
    "Configure status labels: Delivery Status (Awaiting Dispatch, Picked, Dispatched, In Transit, Delivered, Returned)",
    "Configure dropdown values: Production Line (Line 1, Line 2, Line 3 — adapt to client facility)",
    "Configure dropdown values: Shift (Day, Evening, Night, Weekend)",
    "Configure dropdown values: Downtime Reason (Mechanical Failure, Material Shortage, Changeover, Maintenance, Staff Shortage, Other)",
    "Configure dropdown values: Inspection Type (Incoming, In-Process, Final, Audit, Customer Complaint)",
    "Configure dropdown values: Defect Type (Dimensional, Visual, Functional, Packaging, Labeling, Contamination)",
    "Configure dropdown values: Root Cause (Material, Machine, Method, Manpower, Measurement, Environment)",
    "Configure dropdown values: Category (Raw Materials, Components, Packaging, Chemicals, Spare Parts)",
    "Configure dropdown values: Unit of Measure (kg, litres, units, metres, pallets, boxes)",
    "Configure dropdown values: Payment Terms (Net 30, Net 60, Net 90, COD, Prepaid)",
    "Configure dropdown values: Carrier (adapt to client's logistics providers)",
    "Set up views: Production Planning Timeline (Gantt by Start Date to Target Completion)",
    "Set up views: Inventory Kanban (by Stock Status)",
    "Set up views: Dispatch Calendar (by Dispatch Date)",
    "Set up AI Blocks: auto-calculate Scrap Rate from Scrap Units / Quantity Produced",
    "Set up AI Blocks: auto-flag suppliers with rating below 'Satisfactory' and expiring contracts",
    "Set up integrations: barcode/QR scanning for inventory stocktake (mobile monday.com app)"
  ]
}
