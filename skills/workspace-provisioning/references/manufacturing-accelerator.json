        { "title": "Product", "type": "text" },
        { "title": "Quantity", "type": "numbers" },
        { "title": "Dispatch Date", "type": "date" },
        { "title": "Delivery Date", "type": "date" },
        { "title": "Carrier", "type": "dropdown" },
        { "title": "Tracking Number", "type": "text" },
        { "title": "Delivery Status", "type": "status" },
        { "title": "Delivery Address", "type": "long_text" },
        { "title": "Pallet Count", "type": "numbers" },
        { "title": "Weight (kg)", "type": "numbers" },
