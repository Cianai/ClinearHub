        { "title": "Website", "type": "link" },
        { "title": "Products Supplied", "type": "text" },
        { "title": "Supplier Rating", "type": "status" },
        { "title": "Payment Terms", "type": "dropdown" },
        { "title": "Lead Time (days)", "type": "numbers" },
        { "title": "Last Order Date", "type": "date" },
        { "title": "Annual Spend", "type": "numbers" },
        { "title": "Certifications", "type": "tags" },
